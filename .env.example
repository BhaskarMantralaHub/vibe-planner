NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=your_admin_email@example.com

# Sentry error tracking (optional — app works without this)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
# GitHub Actions backup workflow — add as repo secret (not env var)
# SUPABASE_DB_PASSWORD=your_database_password  # Settings > Database > Database password
