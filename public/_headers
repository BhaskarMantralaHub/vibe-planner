/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  # HTML (and anything not overridden below) must be revalidated every load so
  # a redeploy never serves stale HTML that points at deleted JS chunk hashes
  # (the ChunkLoadError / "module factory not available" iOS-Safari bug).
  Cache-Control: no-cache

# Hashed build assets are content-addressed and safe to cache forever. More
# specific path → overrides the no-cache above for these files only.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  Cache-Control: no-cache
